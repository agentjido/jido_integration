defmodule <%= @connector_module %> do
  @moduledoc """
  Scaffolded <%= Atom.to_string(@runtime_class) %> connector package.
  """

  @behaviour Jido.Integration.V2.Connector

  alias Jido.Integration.V2.AuthSpec
  alias Jido.Integration.V2.CatalogSpec
  alias Jido.Integration.V2.Ingress.Definition
  alias Jido.Integration.V2.Manifest
  alias Jido.Integration.V2.OperationSpec
  alias Jido.Integration.V2.TriggerSpec
  alias <%= @handler_module %>
  alias <%= @trigger_handler_module %>

  @trigger_id "<%= @trigger_id %>"
  @signal_type "<%= @trigger_signal_type %>"
  @signal_source "<%= @trigger_signal_source %>"

  @impl true
  def manifest do
    Manifest.new!(%{
      connector: "<%= @connector_name %>",
      auth:
        AuthSpec.new!(%{
          binding_kind: :connection_id,
          supported_profiles:
<%= @auth_supported_profiles_literal %>,
          default_profile: <%= @auth_default_profile_literal %>,
          install: <%= @auth_install_literal %>,
          reauth: <%= @auth_reauth_literal %>,
          management_modes: <%= @auth_management_modes_literal %>,
          requested_scopes: <%= @auth_requested_scopes_literal %>,
          durable_secret_fields: <%= @auth_durable_secret_fields_literal %>,
          lease_fields: <%= @auth_lease_fields_literal %>,
          secret_names: []
        }),
      catalog:
        CatalogSpec.new!(%{
          display_name: "<%= @connector_display_name %>",
          description: "Scaffolded <%= Atom.to_string(@runtime_class) %> connector package",
          category: "developer_tools",
          tags: ["<%= @connector_name %>", "<%= Atom.to_string(@runtime_class) %>"],
          docs_refs: [],
          maturity: :experimental,
          publication: :internal
        }),
      operations: [
        OperationSpec.new!(%{
          operation_id: "<%= @operation_id %>",
          name: "<%= @operation_name %>",
          display_name: "<%= @operation_display_name %>",
          description: "<%= @operation_description %>",
          runtime_class: <%= @runtime_class_literal %>,
          transport_mode: <%= @transport_profile_literal %>,
          handler: <%= @handler_alias %>,
          input_schema:
<%= @input_schema_literal %>,
          output_schema:
<%= @output_schema_literal %>,
          permissions: %{required_scopes: ["<%= @required_scope %>"]},
<%= if @include_runtime_metadata do %>          runtime: %{
            driver: "<%= @runtime_driver_id %>",
<%= if @runtime_provider_literal do %>            provider: <%= @runtime_provider_literal %>,
<% end %>            options: <%= @runtime_options_literal %>
          },
<% end %>          policy: %{
            environment: %{allowed: <%= @environment_allowed_literal %>},
            sandbox: %{
              level: <%= @sandbox_level_literal %>,
              egress: <%= @sandbox_egress_literal %>,
              approvals: <%= @sandbox_approvals_literal %>,
<%= if @session_runtime do %>              file_scope: <%= @sandbox_file_scope_literal %>,
<% end %>              allowed_tools: <%= @allowed_tools_literal %>
            }
          },
          upstream: <%= @upstream_literal %>,
          consumer_surface: %{
            mode: :common,
            normalized_id: "<%= @common_action_normalized_id %>",
            action_name: "<%= @generated_action_name %>"
          },
          schema_policy: %{input: :defined, output: :defined},
          jido: %{action: %{name: "<%= @generated_action_name %>"}},
<%= if @runtime_family_literal do %>          metadata: %{
            runtime_family: <%= @runtime_family_literal %>
          }
<% else %>          metadata: %{}
<% end %>        })
      ],
      triggers: [
        TriggerSpec.new!(%{
          trigger_id: @trigger_id,
          name: "<%= @trigger_name %>",
          display_name: "<%= @trigger_display_name %>",
          description: "<%= @trigger_description %>",
          runtime_class: :direct,
          delivery_mode: :poll,
          polling: <%= @trigger_polling_literal %>,
          handler: <%= @trigger_handler_alias %>,
          config_schema:
<%= @trigger_config_schema_literal %>,
          signal_schema:
<%= @trigger_signal_schema_literal %>,
          permissions: %{required_scopes: ["<%= @required_scope %>"]},
          checkpoint: <%= @trigger_checkpoint_literal %>,
          dedupe: <%= @trigger_dedupe_literal %>,
          verification: %{},
          policy: %{
            environment: %{allowed: <%= @environment_allowed_literal %>},
            sandbox: %{
              level: :standard,
              egress: :restricted,
              approvals: :auto,
              allowed_tools: [@trigger_id]
            }
          },
          consumer_surface: %{
            mode: :common,
            normalized_id: "<%= String.replace(@trigger_name, "_", ".") %>",
            sensor_name: "<%= @trigger_consumer_surface_sensor_name %>"
          },
          schema_policy: %{config: :defined, signal: :defined},
          jido: %{
            sensor: %{
              name: "<%= @trigger_jido_sensor_name %>",
              signal_type: @signal_type,
              signal_source: @signal_source
            }
          }
        })
      ],
      runtime_families: <%= @runtime_families_literal %>
    })
  end

  @spec ingress_definitions() :: [Definition.t()]
  def ingress_definitions do
    <%= @ingress_definitions_literal %>
    |> Enum.map(&Definition.new!/1)
  end
end

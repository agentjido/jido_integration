defmodule <%= @conformance_module %> do
  @moduledoc false
<%= if @include_runtime_drivers do %>
  alias <%= @conformance_harness_driver_module %>
<% end %>

  @spec fixtures() :: [map()]
  def fixtures do
    [
      %{
        capability_id: "<%= @capability_id %>",
        input: <%= @fixture_input_literal %>,
        credential_ref: <%= @fixture_credential_ref_literal %>,
        credential_lease: <%= @fixture_credential_lease_literal %>,
        context: <%= @fixture_context_literal %>,
        expect: %{
          output: <%= @fixture_expect_output_literal %>,
          event_types: <%= @fixture_event_types_literal %>,
          artifact_types: <%= @fixture_artifact_types_literal %>,
          artifact_keys: <%= @fixture_artifact_keys_literal %>
        }
      }
    ]
  end

<%= if @include_runtime_drivers do %>
  @spec runtime_drivers() :: map()
  def runtime_drivers do
    %{<%= @runtime_driver_atom_literal %> => <%= @conformance_harness_driver_alias %>}
  end
<% end %>

<%= if Keyword.get(assigns, :publish_ingress_definitions, false) do %>
  @spec ingress_definitions() :: [map()]
  def ingress_definitions do
    <%= Keyword.get(assigns, :ingress_definitions_literal, "[]") %>
  end
<% end %>
end

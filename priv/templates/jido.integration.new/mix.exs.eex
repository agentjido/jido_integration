Code.require_file("../../build_support/dependency_resolver.exs", __DIR__)

defmodule <%= @project_module %> do
  use Mix.Project

  alias Jido.Integration.Build.DependencyResolver

  def project do
    [
      app: :<%= @app_name %>,
      version: "0.1.0",
      elixir: "~> 1.19",
      start_permanent: Mix.env() == :prod,
      elixirc_paths: elixirc_paths(Mix.env()),
      consolidate_protocols: false,
      deps: deps(),
      dialyzer: dialyzer(),
      docs: docs(),
      name: "<%= @project_name %>",
      description: "<%= @package_description %>"
    ]
  end

  def application do
    [
      extra_applications: [:logger]
    ]
  end

  defp elixirc_paths(_env), do: ["lib"]

  defp deps do
    [
      DependencyResolver.jido_integration_v2_contracts(override: true),
      DependencyResolver.jido_integration_v2_consumer_surfaces(override: true),
      DependencyResolver.jido_integration_v2_direct_runtime(override: true),
      {:jido, "~> 2.1"},
      {:jido_action, "~> 2.1"},
      {:zoi, "~> 0.17"},
      DependencyResolver.jido_integration_v2_conformance(only: :test, runtime: false),
<%= if @include_test_support do %>      DependencyResolver.jido_runtime_control(override: true),
<% end %>      {:credo, "~> 1.7.17", only: [:dev, :test], runtime: false},
      {:dialyxir, "~> 1.4.7", only: [:dev, :test], runtime: false},
      {:ex_doc, "~> 0.40.1", only: :dev, runtime: false}
    ]
  end

  defp dialyzer do
    [plt_add_deps: :apps_direct]
  end

  defp docs do
    [
      main: "readme",
      extras: ["README.md"],
      groups_for_extras: [
        Overview: ["README.md"]
      ]
    ]
  end

end
